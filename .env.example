# Local-only environment template. Never commit real values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

GITHUB_OWNER=your-owner
GITHUB_REPO=your-repository
GITHUB_BRANCH=main
GITHUB_TOKEN=
GITHUB_GIST_TOKEN=
POSTS_PATH=src/content/posts
MOMENTS_GIST_ID=
MOMENTS_FILE_NAME=moments.json
NOTEBOOK_GISTS_JSON={}

IMG_BED_URL=https://mourn.kdns.fr/
IMG_BED_TOKEN=

# Optional integrations; only configure a value when the feature is enabled.
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_TOKEN=
WEATHER_API_KEY=
HUGGINGFACE_TOKEN=

# Leave unset for ordinary local development (`pnpm dev`).
# Enabling this forces the Cloudflare adapter, which expects dist/_worker.js
# and breaks the Astro-native local server used by `pnpm dev` / `pnpm check`.
# CF_WORKERS=true

---
import { siteConfig } from "@/config";

const devtoolsWarning = siteConfig.devtoolsWarning || {};
---

<script is:inline define:vars={{ devtoolsWarning }}>
(function () {
  const duration = (devtoolsWarning.time || 5) * 1000;

  const style = document.createElement("style");

  style.textContent = `
  #devtools-warning {
    position: fixed;
    top: 24px;
    left: 50%;

    transform:
      translateX(-50%)
      translateY(-40px)
      scale(.95);

    width: min(92vw, 460px);

    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);

    background: rgba(255,255,255,0.55);

    border: 1px solid rgba(255,255,255,0.55);

    border-radius: 26px;

    box-shadow:
      0 20px 50px rgba(0,0,0,.12),
      0 8px 20px rgba(0,0,0,.08);

    overflow: hidden;

    z-index: 999999;

    opacity: 0;
    pointer-events: none;

    transition:
      transform .45s cubic-bezier(.22,1,.36,1),
      opacity .35s ease;
  }

  :root.dark #devtools-warning {
    background: rgba(17,24,39,.88);

    border: 1px solid rgba(255,255,255,.08);

    box-shadow:
      0 20px 60px rgba(0,0,0,.45),
      0 0 0 1px rgba(255,255,255,.05);
  }

  #devtools-warning.show {
    opacity: 1;

    transform:
      translateX(-50%)
      translateY(0)
      scale(1);
  }

  #devtools-warning.hide {
    opacity: 0;

    transform:
      translateX(-50%)
      translateY(-20px)
      scale(.96);
  }

  #devtools-warning-content {
    padding: 18px 20px;

    display: flex;
    align-items: center;
    gap: 16px;
  }

  #devtools-warning-icon {
    width: 52px;
    height: 52px;

    border-radius: 16px;

    flex-shrink: 0;

    background:
      linear-gradient(
        135deg,
        #fbbf24,
        #f97316
      );

    box-shadow:
      0 12px 30px rgba(249,115,22,.35);

    display: flex;
    align-items: center;
    justify-content: center;

    color: white;

    font-size: 24px;
  }

  #devtools-warning-text {
    flex: 1;
    min-width: 0;
  }

  #devtools-warning-title {
    font-size: 15px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 4px;
  }

  #devtools-warning-desc {
    font-size: 13px;
    line-height: 1.6;
    color: #6b7280;
  }

  :root.dark #devtools-warning-title {
    color: #f9fafb;
  }

  :root.dark #devtools-warning-desc {
    color: rgba(255,255,255,.7);
  }

  #devtools-warning-timer {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    position: relative;
  }

  #devtools-warning-timer svg {
    width: 42px;
    height: 42px;
    transform: rotate(-90deg);
  }

  #devtools-warning-timer-bg {
    fill: none;
    stroke: rgba(0,0,0,.08);
    stroke-width: 3;
  }

  :root.dark #devtools-warning-timer-bg {
    stroke: rgba(255,255,255,.08);
  }

  #devtools-warning-timer-progress {
    fill: none;
    stroke: #f97316;
    stroke-width: 3;
    stroke-linecap: round;

    stroke-dasharray: 113;
    stroke-dashoffset: 0;

    transition: stroke-dashoffset linear;
  }

  #devtools-warning-timer-text {
    position: absolute;
    inset: 0;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 11px;
    font-weight: 700;
    color: #f97316;
  }

  @media (max-width:640px) {
    #devtools-warning {
      width: calc(100vw - 20px);
      top: 12px;
    }

    #devtools-warning-content {
      padding: 16px;
    }

    #devtools-warning-icon {
      width: 46px;
      height: 46px;
      font-size: 20px;
    }

    #devtools-warning-title {
      font-size: 14px;
    }

    #devtools-warning-desc {
      font-size: 12px;
    }
  }
  `;

  document.head.appendChild(style);

  const warning = document.createElement("div");

  warning.id = "devtools-warning";

  warning.innerHTML = `
    <div id="devtools-warning-content">

      <div id="devtools-warning-icon">
        ⚠
      </div>

      <div id="devtools-warning-text">
        <div id="devtools-warning-title">
          开发者工具已打开
        </div>

        <div id="devtools-warning-desc">
          ${
            devtoolsWarning.message ||
            "请勿执行未知脚本、篡改页面内容或调试敏感逻辑。"
          }
        </div>
      </div>

      <div id="devtools-warning-timer">
        <svg viewBox="0 0 42 42">
          <circle
            id="devtools-warning-timer-bg"
            cx="21"
            cy="21"
            r="18"
          />
          <circle
            id="devtools-warning-timer-progress"
            cx="21"
            cy="21"
            r="18"
          />
        </svg>

        <div id="devtools-warning-timer-text">
          ${devtoolsWarning.time || 5}
        </div>
      </div>

    </div>
  `;

  document.body.appendChild(warning);

  let warningTimer = null;

function showWarning() {
  if (!document.body.contains(warning)) {
    document.body.appendChild(warning);
  }

  clearTimeout(warningTimer);

  warning.classList.remove("hide");
  warning.classList.remove("show");

  void warning.offsetWidth;

  warning.classList.add("show");

  const progress =
    warning.querySelector(
      "#devtools-warning-timer-progress"
    );

  const text =
    warning.querySelector(
      "#devtools-warning-timer-text"
    );

  const circumference = 113;

  progress.style.transition = "none";
  progress.style.strokeDashoffset = 0;

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      progress.style.transition =
        `stroke-dashoffset ${duration}ms linear`;

      progress.style.strokeDashoffset =
        circumference;
    });
  });

  let remaining =
    devtoolsWarning.time || 5;

  text.textContent = remaining;

  const interval = setInterval(() => {
    remaining--;

    if (remaining >= 0) {
      text.textContent = remaining;
    }
  }, 1000);

  warningTimer = setTimeout(() => {
    clearInterval(interval);

    warning.classList.remove("show");
    warning.classList.add("hide");
  }, duration);
}

/* 快捷键触发 */

document.addEventListener("keydown", (e) => {
  if (e.key === "F12") {
    showWarning();
    return;
  }

  if (
    e.ctrlKey &&
    e.shiftKey &&
    ["I", "J", "C"].includes(
      e.key.toUpperCase()
    )
  ) {
    showWarning();
    return;
  }

  if (
    e.metaKey &&
    e.altKey &&
    ["I", "J", "C"].includes(
      e.key.toUpperCase()
    )
  ) {
    showWarning();
    return;
  }
});

/* DevTools 状态检测 */

let devtoolsOpened = false;

const threshold = 160;

function detectDevTools() {
  const widthDiff =
    window.outerWidth -
    window.innerWidth;

  const heightDiff =
    window.outerHeight -
    window.innerHeight;

  const opened =
    widthDiff > threshold ||
    heightDiff > threshold;

  if (opened && !devtoolsOpened) {
    devtoolsOpened = true;
    showWarning();
  }

  if (!opened && devtoolsOpened) {
    devtoolsOpened = false;
  }
}

/* 首次检测 */

detectDevTools();

/* 持续监听 */

window.addEventListener(
  "resize",
  detectDevTools
);

setInterval(
  detectDevTools,
  1000
);

  document.addEventListener("keydown", (e) => {
    if (e.key === "F12") {
      showWarning();
      return;
    }

    if (
      e.ctrlKey &&
      e.shiftKey &&
      ["I", "J", "C"].includes(
        e.key.toUpperCase()
      )
    ) {
      showWarning();
      return;
    }

    if (
      e.metaKey &&
      e.altKey &&
      ["I", "J", "C"].includes(
        e.key.toUpperCase()
      )
    ) {
      showWarning();
      return;
    }
  });
})();
</script>